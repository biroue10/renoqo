# Renoqo — modèle de configuration d'environnement
#
# ATTENTION : ce fichier est versionné dans Git.
# Il ne doit contenir QUE des valeurs fictives, jamais de données réelles
# (identifiants, mots de passe, tokens, clés d'API, chaînes de connexion de production).
#
# Pour un usage local : copier ce fichier vers .env (ignoré par Git) puis y mettre vos valeurs.
#   cp .env.example .env

APP_NAME=Renoqo
APP_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_GA_ID=

DATABASE_URL=postgresql://user:password@localhost:5432/renoqo
